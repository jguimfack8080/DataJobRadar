# Data Job Radar Deutschland - Umgebungskonfiguration (Vorlage)
# Echte Werte gehoeren in .env (nicht versioniert) und niemals in den Code.

# Adzuna API
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
ADZUNA_COUNTRY=de
ADZUNA_BASE_URL=https://api.adzuna.com/v1/api
ADZUNA_RESULTS_PER_PAGE=50
ADZUNA_TIMEOUT_SECONDS=30
ADZUNA_MAX_RETRIES=5

# Backend
BACKEND_PORT=8081
BACKEND_HOST=0.0.0.0
BACKEND_LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000,http://pgadmin.thetransporterlabs.de
BACKEND_CACHE_TTL_SECONDS=300
BACKEND_RATE_LIMIT_PER_MINUTE=120

# Data Lake / Analytics
DATA_LAKE_ROOT=/data/lake
DUCKDB_PATH=/data/warehouse/djr.duckdb

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8081/api/v1
NEXT_PUBLIC_APP_NAME=Data Job Radar Deutschland

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__FERNET_KEY=generate-a-fernet-key-and-place-here
AIRFLOW__WEBSERVER__SECRET_KEY=replace-with-strong-random-secret
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=replace-with-strong-random-secret
AIRFLOW_DB_NAME=airflow
AIRFLOW_WEBSERVER_PORT=8080

# Observability
LOG_FORMAT=json
LOG_LEVEL=INFO
